{% extends "templates/base.html" %}
{% include "templates/partials/header.html" %}
{% import "templates/macros/forms.html" as forms %}
{% from "templates/macros/forms.html" import btn as btn_local %}

{% set title = "Demo" %}

{% macro local_macro(p) %}
  {{ p }}
{% endmacro %}

{% block content %}
  {{ title }}

  {% for item in [1, 2, 3] %}
    {{ item }}
  {% endfor %}

  {{ forms }}
  {{ btn_local("OK") }}
  {{ local_macro("X") }}

  {{ unknown_name }}
{% endblock %}
