{# ----------------------------------------------------------------------
  CONTROL: if/elif/else + nested
----------------------------------------------------------------------- #}
{% set x=1 %}
{% set y=1 %}

{% if x > 0 and y > 0 %}
  {% if x != y %}
    X!=Y
  {% else %}
    X==Y
  {% endif %}
{% elif x == 0 %}
  X==0
{% else %}
  X<0
{% endif %}

{# ----------------------------------------------------------------------
  LOOPS: for, for-else, nested, loop vars, for-if, recursive
----------------------------------------------------------------------- #}
{% for i in range(0, 3) %}
  {{ loop.index }} {{ loop.index0 }} {{ loop.revindex }} {{ loop.revindex0 }}
  {{ loop.first }} {{ loop.last }} {{ loop.length }}
  {{ loop.cycle("A", "B") }}={{ i }}
{% endfor %}

{% set empty_seq=[] %}

{% for v in empty_seq %}
  {{ v }}
{% else %}
  EMPTY LOOP
{% endfor %}

{% for k, v in mp.items() %}
  {{ k }}={{ v }}
{% endfor %}

{% for i in seq if i is even %}
  EVEN={{ i }}
{% endfor %}

{% set tree = [{"name":"root","children":[{"name":"a","children":[]},{"name":"b","children":[{"name":"b1","children":[]}]}]}] %}
{% for node in tree recursive %}
  {{ "-" * loop.depth0 }}{{ node.name }}
  {% if node.children %}
    {{ loop(node.children) }}
  {% endif %}
{% endfor %}

